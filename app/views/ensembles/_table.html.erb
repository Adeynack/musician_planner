<div id="ensembles">
  <table class="table">
    <thead>
      <tr>
        <th scope="col">Name</th>
        <th scope="col">eMail</th>
        <th scope="col">Website</th>
      </tr>
    </thead>
    <tbody>
      <% ensembles.each do |ensemble| %>
        <tr>
          <td><%= link_to ensemble.name, ensemble %></td>
          <td><%= link_to ensemble.email.truncate(20), "mailto:#{ensemble.email}" %></td>
          <td><%= link_to ensemble.website.truncate(30), ensemble.website, target: "_blank" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
