<%= form_with(model: ensemble) do |form| %>
  <% if ensemble.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(ensemble.errors.count, "error") %> prohibited this ensemble from being saved:</h2>
      <ul>
        <% ensemble.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="mb-3">
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>
  <div class="mb-3">
    <%= form.label :website, style: "display: block" %>
    <%= form.text_field :website %>
  </div>
  <div class="mb-3">
    <%= form.label :email, style: "display: block" %>
    <%= form.text_field :email %>
  </div>
  <%= form.submit %>
<% end %>
